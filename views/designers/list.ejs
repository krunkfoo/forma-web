<%- include('../layout', { title: 'Find a Designer — Forma', body: `
<div class="marketplace-page">
  <div class="marketplace-header">
    <h1>Find a designer</h1>
    <p>Browse verified professionals with space-design experience</p>
  </div>

  <form class="marketplace-filters" method="GET" action="/designers">
    <input type="text" name="q" placeholder="Search by name or location…" value="${q}" />
    <select name="specialty">
      <option value="">All specialties</option>
      <option value="interior" ${specialty === 'interior' ? 'selected' : ''}>Interior design</option>
      <option value="landscape" ${specialty === 'landscape' ? 'selected' : ''}>Landscape / outdoor</option>
      <option value="kitchen" ${specialty === 'kitchen' ? 'selected' : ''}>Kitchen & bath</option>
      <option value="commercial" ${specialty === 'commercial' ? 'selected' : ''}>Commercial</option>
    </select>
    <button type="submit" class="btn-primary btn-sm">Search</button>
  </form>

  ${designers.length === 0 ? `
    <div class="empty-state">
      <p>No designers found for those filters.</p>
    </div>
  ` : `
  <div class="designer-grid">
    ${designers.map(d => `
    <a href="/designers/${d.id}" class="designer-card">
      <div class="designer-card-avatar">
        ${d.avatar_url
          ? `<img src="${d.avatar_url}" alt="${d.name}" />`
          : `<div class="avatar-placeholder">${d.name.charAt(0)}</div>`}
        ${d.available ? '<span class="avail-dot"></span>' : ''}
      </div>
      <div class="designer-card-body">
        <h3>${d.name}</h3>
        ${d.location ? `<p class="designer-location">📍 ${d.location}</p>` : ''}
        ${d.specialties && d.specialties.length ? `
          <div class="tag-row">
            ${d.specialties.map(s => `<span class="tag">${s}</span>`).join('')}
          </div>
        ` : ''}
        ${d.bio ? `<p class="designer-bio">${d.bio.substring(0, 100)}${d.bio.length > 100 ? '…' : ''}</p>` : ''}
        <div class="designer-footer">
          <div class="rating">
            ${'★'.repeat(Math.round(d.rating || 0))}${'☆'.repeat(5 - Math.round(d.rating || 0))}
            <span>${d.review_count || 0} review${d.review_count === 1 ? '' : 's'}</span>
          </div>
          ${d.rate_per_hr ? `<span class="rate">$${Math.round(d.rate_per_hr)}/hr</span>` : ''}
        </div>
      </div>
    </a>
    `).join('')}
  </div>
  `}
</div>
` }) %>
