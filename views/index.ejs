<%- include('layout', { title: 'Forma — AI-powered space design', body: `

<section class="hero">
  <div class="hero-inner">
    <div class="hero-badge">Now on iOS · LiDAR-powered</div>
    <h1 class="hero-title">Design any space.<br/>Indoors &amp; out.</h1>
    <p class="hero-subtitle">Scan your room or yard with LiDAR, get AI-generated design options, and hire a professional to bring it to life.</p>
    <div class="hero-actions">
      <a href="/register" class="btn-primary">Get started free</a>
      <a href="/designers" class="btn-ghost">Browse designers →</a>
    </div>
  </div>
  <div class="hero-visual">
    <div class="mockup-phone">
      <div class="mockup-screen">
        <div class="mockup-floor-plan">
          <svg viewBox="0 0 200 160" xmlns="http://www.w3.org/2000/svg">
            <!-- Floor plan outline -->
            <rect x="20" y="20" width="160" height="120" rx="2" fill="none" stroke="#33E566" stroke-width="2"/>
            <!-- Room dividers -->
            <line x1="100" y1="20" x2="100" y2="100" stroke="#33E566" stroke-width="1.5" stroke-dasharray="4,2"/>
            <line x1="20" y1="100" x2="160" y2="100" stroke="#33E566" stroke-width="1.5" stroke-dasharray="4,2"/>
            <!-- Door arc -->
            <path d="M20 65 Q35 65 35 80" fill="none" stroke="#33E566" stroke-width="1"/>
            <!-- Furniture -->
            <rect x="30" y="30" width="50" height="35" rx="3" fill="#33E56620" stroke="#33E566" stroke-width="1"/>
            <rect x="110" y="30" width="60" height="25" rx="3" fill="#33E56620" stroke="#33E566" stroke-width="1"/>
            <!-- Labels -->
            <text x="55" y="75" text-anchor="middle" fill="#33E566" font-size="8" font-family="Inter, sans-serif">Living</text>
            <text x="140" y="75" text-anchor="middle" fill="#33E566" font-size="8" font-family="Inter, sans-serif">Kitchen</text>
            <text x="90" y="130" text-anchor="middle" fill="#33E566" font-size="8" font-family="Inter, sans-serif">Bedroom</text>
            <!-- Scan dot -->
            <circle cx="168" cy="22" r="3" fill="#33E566">
              <animate attributeName="opacity" values="1;0.3;1" dur="2s" repeatCount="indefinite"/>
            </circle>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="features">
  <div class="features-inner">
    <h2 class="section-title">Everything you need to transform a space</h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">📱</div>
        <h3>LiDAR Scan</h3>
        <p>Use your iPhone's LiDAR sensor to capture a precise 3D model of any room or outdoor space in under a minute.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">✨</div>
        <h3>AI Design</h3>
        <p>Get photorealistic design options generated by AI. Choose your style — modern, Scandinavian, Mediterranean, and more.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🗺️</div>
        <h3>Site Plan</h3>
        <p>Automatically generated 2D floor plans with accurate dimensions. Export as PDF for contractors and permits.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">👷</div>
        <h3>Hire a Pro</h3>
        <p>Share your 3D scan and AI designs with verified designers. Get quotes, compare portfolios, and hire on-platform.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🧱</div>
        <h3>Materials List</h3>
        <p>Auto-generated bill of materials with cost estimates. Know your budget before you break ground.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🌿</div>
        <h3>Vastu & Feng Shui</h3>
        <p>Optional AI analysis of your space for energy flow, sun orientation, and traditional design principles.</p>
      </div>
    </div>
  </div>
</section>

<section class="how-it-works">
  <div class="hiw-inner">
    <h2 class="section-title">How it works</h2>
    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <h3>Scan your space</h3>
        <p>Open the Forma app and slowly walk around your room or yard. LiDAR captures a colour 3D mesh in real time.</p>
      </div>
      <div class="step-arrow">→</div>
      <div class="step">
        <div class="step-num">2</div>
        <h3>Review &amp; design</h3>
        <p>See your 3D floor plan instantly. Pick a style and watch AI generate a photorealistic redesign in under 30 seconds.</p>
      </div>
      <div class="step-arrow">→</div>
      <div class="step">
        <div class="step-num">3</div>
        <h3>Hire or DIY</h3>
        <p>Share your project with a designer from our marketplace, or follow the AI-generated step-by-step project guide yourself.</p>
      </div>
    </div>
  </div>
</section>

<section class="designer-cta">
  <div class="cta-inner">
    <div class="cta-content">
      <h2>Are you a designer or contractor?</h2>
      <p>Join the Forma marketplace and get matched with homeowners who have a LiDAR scan ready to go. No cold outreach — clients come to you with 3D models in hand.</p>
      <a href="/register?role=designer" class="btn-primary">Join as a designer</a>
    </div>
  </div>
</section>

` }) %>
